class ChatClient {
    function constructor() {
        $this->messages = []
        $this->model = System::env("AI_MODEL") ?? "llama-3.3-70b-specdec"
    }

    function user($msg) {
        $this->messages = append($this->messages, {"role": "user", "content": $msg})
        return $this
    }

    function system($msg) {
        $this->messages = append($this->messages, {"role": "system", "content": $msg})
        return $this
    }

    function assistant($msg) {
        $this->messages = append($this->messages, {"role": "assistant", "content": $msg})
        return $this
    }

    function call() {
        $apiKey = System::env("GROQ_API_KEY")
        $url = "https://api.groq.com/openai/v1/chat/completions"

        $payload = {
            "model": $this->model,
            "messages": $this->messages
        }

        $jsonPayload = JSON::stringify($payload)

        // Make curl request via System::Run
        $args = [
            "-s",
            "-X", "POST",
            "-H", "Content-Type: application/json",
            "-H", "Authorization: Bearer " . $apiKey,
            "-d", $jsonPayload,
            $url
        ]

        $output = System::Run("curl", $args)
        $data = JSON::parse($output)

        // Extract result
        $choices = $data["choices"]
        $first = $choices[0]
        $message = $first["message"]
        return $message["content"]
    }
}

class AI {
    function client() {
        return new ChatClient()
    }
}
